{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "command": "nx run build --no-tui --no-interactive --configuration development",
            "problemMatcher": "$tsc",
            "label": "nx: compile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "type": "shell",
            "command": "nx run watch",
            "label": "nx: watch",
            "isBackground": true,
            "problemMatcher": {
                "owner": "nx-watch",
                "pattern": { "regexp": "^$" },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "built in"
                }
            }
        }
    ]
}
