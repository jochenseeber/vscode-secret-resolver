{
    "inputs": [
        {
            "id": "opAccountId",
            "type": "promptString",
            "description": "Enter the 1Password account ID to use for this launch"
        },
        {
            "id": "opAccountEmail",
            "type": "promptString",
            "description": "Enter the 1Password account email address (e.g. user@example.com)"
        }
    ],
    "configurations": [
        {
            "name": "Test Node Launch: Integrated Terminal",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/TestNodeLaunch1.js",
            "console": "integratedTerminal",
            "env": {
                "TEST_SECRET": "op://Development/Secret Resolver Extension Test/password",
                "TEST_HELLO": "Hello, World!"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Test Node Launch: External Terminal",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/TestNodeLaunch1.js",
            "console": "externalTerminal",
            "env": {
                "TEST_SECRET": "op://Development/Secret Resolver Extension Test/password",
                "TEST_HELLO": "Hello, World!"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Test Node Launch: Internal Console",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/TestNodeLaunch1.js",
            "console": "internalConsole",
            "env": {
                "TEST_SECRET": "op://Development/Secret Resolver Extension Test/password",
                "TEST_HELLO": "Hello, World!"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Test Java Launch: Integrated Terminal",
            "type": "java",
            "request": "launch",
            "mainClass": "${workspaceFolder}/TestJavaLaunch1.java",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "TEST_SECRET": "op://Development/Secret Resolver Extension Test/password",
                "TEST_HELLO": "Hello, World!"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Test Java Launch: External Terminal",
            "type": "java",
            "request": "launch",
            "mainClass": "${workspaceFolder}/TestJavaLaunch1.java",
            "cwd": "${workspaceFolder}",
            "console": "externalTerminal",
            "env": {
                "TEST_SECRET": "op://Development/Secret Resolver Extension Test/password",
                "TEST_HELLO": "Hello, World!"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Test Java Launch: Internal Console",
            "type": "java",
            "request": "launch",
            "mainClass": "${workspaceFolder}/TestJavaLaunch1.java",
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "env": {
                "TEST_SECRET": "op://Development/Secret Resolver Extension Test/password",
                "TEST_HELLO": "Hello, World!"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Test Node Launch: Integrated Terminal (signal-on-stop term+kill)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/TestNodeLaunch1.js",
            "console": "integratedTerminal",
            "env": {
                "SECRET_RESOLVER_SIGNAL_ON_STOP": "int+5:kill",
                "TEST_SECRET": "op://Development/Secret Resolver Extension Test/password",
                "TEST_HELLO": "Hello, World!"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Test Java Launch: External Terminal (signal-on-stop term+kill)",
            "type": "java",
            "request": "launch",
            "mainClass": "${workspaceFolder}/TestJavaLaunch1.java",
            "cwd": "${workspaceFolder}",
            "console": "externalTerminal",
            "env": {
                "SECRET_RESOLVER_SIGNAL_ON_STOP": "int+5:kill",
                "TEST_SECRET": "op://Development/Secret Resolver Extension Test/password",
                "TEST_HELLO": "Hello, World!"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Test Java Launch: Integrated Terminal (no op references)",
            "type": "java",
            "request": "launch",
            "mainClass": "${workspaceFolder}/TestJavaLaunch1.java",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "Test Java Launch: External Terminal (no op references)",
            "type": "java",
            "request": "launch",
            "mainClass": "${workspaceFolder}/TestJavaLaunch1.java",
            "cwd": "${workspaceFolder}",
            "console": "externalTerminal"
        },
        {
            "name": "Test Node Launch: Integrated Terminal (token tag)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/TestNodeLaunch1.js",
            "console": "integratedTerminal",
            "env": {
                "SECRET_RESOLVER_TOKEN_TAG": "token/development",
                "TEST_SECRET": "op://Development/Secret Resolver Extension Test/password",
                "TEST_HELLO": "Hello, World!"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Test Node Launch: Integrated Terminal (token tag + account email)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/TestNodeLaunch1.js",
            "console": "integratedTerminal",
            "env": {
                "SECRET_RESOLVER_TOKEN_TAG": "token/development",
                "SECRET_RESOLVER_ACCOUNT_EMAIL": "${input:opAccountEmail}",
                "TEST_SECRET": "op://Development/Secret Resolver Extension Test/password",
                "TEST_HELLO": "Hello, World!"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Test Node Launch: Integrated Terminal (token tag + account id)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/TestNodeLaunch1.js",
            "console": "integratedTerminal",
            "env": {
                "SECRET_RESOLVER_TOKEN_TAG": "token/development",
                "SECRET_RESOLVER_ACCOUNT_ID": "${input:opAccountId}",
                "TEST_SECRET": "op://Development/Secret Resolver Extension Test/password",
                "TEST_HELLO": "Hello, World!"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Test Node Launch: Integrated Terminal (token tag + account git config)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/TestNodeLaunch1.js",
            "console": "integratedTerminal",
            "env": {
                "SECRET_RESOLVER_ACCOUNT_GIT_CONFIG": ".",
                "SECRET_RESOLVER_TOKEN_TAG": "token/development",
                "TEST_SECRET": "op://Development/Secret Resolver Extension Test/password",
                "TEST_HELLO": "Hello, World!"
            },
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}
