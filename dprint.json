{
    "$schema": "https://dprint.dev/schemas/v0.json",
    "excludes": [
        "**/.serena",
        "**/.vscode-test",
        "**/dist",
        "**/node_modules",
        "**/pkg",
        ".serena",
        "pnpm-lock.yaml"
    ],
    "includes": [
        "**/*.cjs",
        "**/*.css",
        "**/*.html",
        "**/*.js",
        "**/*.json",
        "**/*.jsx",
        "**/*.less",
        "**/*.md",
        "**/*.mjs",
        "**/*.scss",
        "**/*.ts",
        "**/*.tsx",
        "**/*.yaml",
        "**/*.yml"
    ],
    "indentWidth": 4,
    "json": {},
    "malva": {
        "indentWidth": 2,
        "printWidth": 120
    },
    "markdown": {
        "lineWidth": 79,
        "textWrap": "always"
    },
    "markup": {
        "indentWidth": 2,
        "preferAttrsSingleLine": true,
        "printWidth": 120
    },
    "newLineKind": "lf",
    "plugins": [
        "https://plugins.dprint.dev/g-plane/malva-v0.15.3.wasm",
        "https://plugins.dprint.dev/g-plane/markup_fmt-v0.27.0.wasm",
        "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm",
        "https://plugins.dprint.dev/json-0.21.3.wasm",
        "https://plugins.dprint.dev/markdown-0.21.1.wasm",
        "https://plugins.dprint.dev/typescript-0.95.15.wasm"
    ],
    "typescript": {
        "nextControlFlowPosition": "nextLine",
        "semiColons": "asi"
    },
    "useTabs": false,
    "yaml": {
        "formatComments": true,
        "indentWidth": 2,
        "printWidth": 120,
        "proseWrap": "always",
        "quotes": "forceDouble"
    }
}
