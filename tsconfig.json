{
    "compilerOptions": {
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "lib": [
            "ES2022"
        ],
        "module": "commonjs",
        "outDir": "dist",
        "rootDir": ".",
        "skipLibCheck": true,
        "sourceMap": true,
        "strict": true,
        "target": "ES2022",
        "types": [
            "node",
            "vscode",
            "mocha"
        ]
    },
    "include": [
        "src/**/*.ts",
        "spec/**/*.ts",
        "test/**/*.ts"
    ]
}
