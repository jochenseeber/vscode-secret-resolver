{
    "enabledPlugins": {
        "claude-code-setup@claude-plugins-official": true,
        "claude-md-management@claude-plugins-official": true,
        "code-simplifier@claude-plugins-official": true,
        "context7@claude-plugins-official": true,
        "nx@nx-claude-plugins": true,
        "ralph-loop@claude-plugins-official": true,
        "serena@claude-plugins-official": true,
        "superpowers@claude-plugins-official": true
    },
    "extraKnownMarketplaces": {
        "nx-claude-plugins": {
            "source": {
                "repo": "nrwl/nx-ai-agents-config",
                "source": "github"
            }
        }
    },
    "hooks": {
        "PreToolUse": [
            {
                "hooks": [
                    {
                        "command": "uvx --from git+https://github.com/oraios/serena -- serena-hooks remind --client=claude-code",
                        "type": "command"
                    }
                ],
                "matcher": ""
            }
        ],
        "SessionEnd": [
            {
                "hooks": [
                    {
                        "command": "uvx --from git+https://github.com/oraios/serena -- serena-hooks cleanup --client=claude-code",
                        "type": "command"
                    }
                ],
                "matcher": ""
            }
        ],
        "SessionStart": [
            {
                "hooks": [
                    {
                        "command": "uvx --from git+https://github.com/oraios/serena -- serena-hooks activate --client=claude-code",
                        "type": "command"
                    }
                ],
                "matcher": ""
            }
        ]
    },
    "permissions": {
        "allow": [
            "Skill(update-config)",
            "Skill(update-config:*)",
            "WebFetch(domain:raw.githubusercontent.com)",
            "mcp__playwright__browser_evaluate",
            "mcp__playwright__browser_navigate",
            "mcp__plugin_context7_context7__query-docs",
            "mcp__plugin_serena_serena__activate_project",
            "mcp__plugin_serena_serena__check_onboarding_performed",
            "mcp__plugin_serena_serena__create_text_file",
            "mcp__plugin_serena_serena__find_symbol",
            "mcp__plugin_serena_serena__get_symbols_overview",
            "mcp__plugin_serena_serena__initial_instructions",
            "mcp__plugin_serena_serena__insert_after_symbol",
            "mcp__plugin_serena_serena__list_dir",
            "mcp__plugin_serena_serena__onboarding",
            "mcp__plugin_serena_serena__read_file",
            "mcp__plugin_serena_serena__replace_content",
            "mcp__plugin_serena_serena__replace_symbol_body",
            "mcp__plugin_serena_serena__search_for_pattern",
            "mcp__plugin_serena_serena__write_memory",
            "mcp__serena__activate_project",
            "mcp__serena__initial_instructions"
        ]
    },
    "sandbox": {
        "allowUnsandboxedCommands": false,
        "enableWeakerNetworkIsolation": true,
        "enabled": true,
        "failIfUnavailable": true,
        "filesystem": {
            "allowRead": [
                ".",
                "~/.cache/pnpm",
                "~/.cache/uv",
                "~/.claude",
                "~/.config/gh",
                "~/.config/git",
                "~/.config/op",
                "~/.config/vsrun",
                "~/.gitconfig",
                "~/.gitignore_global",
                "~/.local/bin",
                "~/.local/share/uv",
                "~/.npmrc",
                "~/.rbenv",
                "~/.serena",
                "~/.vscode/argv.json",
                "~/CLAUDE.md",
                "~/Library/Caches/dprint",
                "~/Library/Caches/pnpm",
                "~/Library/Group Containers/2BUA8C4S2C.com.1password",
                "~/Library/pnpm/store"
            ],
            "allowWrite": [
                "~/.cache/pnpm",
                "~/.cache/uv",
                "~/.local/share/uv",
                "~/.serena",
                "~/Library/Caches/dprint",
                "~/Library/Caches/pnpm",
                "~/Library/pnpm"
            ],
            "denyRead": [
                "~/"
            ]
        },
        "network": {
            "allowAllUnixSockets": true,
            "allowMachLookup": [
                "2BUA8C4S2C.com.1password.*",
                "com.1password.*",
                "com.apple.SecurityServer"
            ],
            "allowUnixSockets": [
                "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock",
                "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/s.sock"
            ],
            "allowedDomains": [
                "api.github.com",
                "codeload.github.com",
                "files.pythonhosted.org",
                "github.com",
                "objects.githubusercontent.com",
                "plugins.dprint.dev",
                "pypi.org",
                "raw.githubusercontent.com",
                "registry.npmjs.org",
                "uploads.github.com"
            ]
        }
    }
}
