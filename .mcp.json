{
    "mcpServers": {
        "playwright": {
            "args": [
                "dlx",
                "@playwright/mcp@latest"
            ],
            "command": "pnpm"
        },
        "serena": {
            "args": [
                "--from",
                "git+https://github.com/oraios/serena",
                "serena",
                "start-mcp-server",
                "--context",
                "claude-code",
                "--enable-web-dashboard",
                "false"
            ],
            "command": "uvx"
        }
    },
    "serena": {
        "args": [
            "start-mcp-server",
            "--context",
            "claude-code"
        ],
        "command": "serena"
    }
}
