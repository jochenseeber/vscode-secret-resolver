{
    "activationEvents": [
        "onDebug"
    ],
    "bugs": {
        "url": "https://github.com/jochenseeber/vscode-secret-resolver/issues"
    },
    "capabilities": {
        "untrustedWorkspaces": {
            "description": "Resolves op:// references from launch configurations. Only enable in workspaces you trust — launch configs can reference secrets from any vault the signed-in op CLI can read.",
            "supported": "limited"
        },
        "virtualWorkspaces": false
    },
    "categories": [
        "Debuggers"
    ],
    "contributes": {
        "commands": [
            {
                "category": "Secret Resolver",
                "command": "secretResolver.clearCache",
                "title": "Clear Cache"
            }
        ],
        "configuration": {
            "properties": {
                "secretResolver.opPath": {
                    "default": "op",
                    "description": "Path to the 1Password CLI binary. Looked up on PATH when unqualified.",
                    "type": "string"
                }
            },
            "title": "Secret Resolver"
        }
    },
    "dependencies": {},
    "description": "Resolves 1Password secret references in VS Code launch configuration environment variables",
    "devDependencies": {
        "@eslint/compat": "^2.0.5",
        "@resvg/resvg-js": "^2.6.2",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@tabler/icons": "^3.41.1",
        "@types/mocha": "^10.0.10",
        "@types/node": "^20.19.39",
        "@types/vscode": "^1.116.0",
        "@vscode/debugprotocol": "^1.68.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.9.1",
        "conventional-changelog": "^7.2.0",
        "conventional-changelog-conventionalcommits": "^9.3.1",
        "dprint": "^0.54.0",
        "eslint": "^10.2.1",
        "mocha": "^11.7.5",
        "nx": "^22.7.1",
        "ovsx": "^0.10.11",
        "pidtree": "^0.6.0",
        "shx": "^0.4.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1",
        "vite": "^8.0.10",
        "vitest": "^4.1.5"
    },
    "displayName": "Secret Resolver",
    "engines": {
        "node": ">=20",
        "pnpm": ">=10 <11",
        "vscode": "^1.116.0"
    },
    "files": [
        "CHANGELOG.md",
        "LICENSE.txt",
        "README.md",
        "dist/extension.js",
        "images/"
    ],
    "galleryBanner": {
        "color": "#fffbeb",
        "theme": "light"
    },
    "homepage": "https://github.com/jochenseeber/vscode-secret-resolver#readme",
    "icon": "images/icon.png",
    "keywords": [
        "1password",
        "debug",
        "env",
        "environment",
        "launch",
        "op",
        "secrets"
    ],
    "license": "MIT",
    "main": "./dist/extension.js",
    "name": "vscode-secret-resolver",
    "packageManager": "pnpm@10.33.0",
    "pnpm": {
        "overrides": {
            "serialize-javascript": "7.0.5"
        }
    },
    "preview": true,
    "publisher": "jochenseeber",
    "qna": "marketplace",
    "releaseBranchSuffix": "-dev",
    "releaseRefPrefix": "v",
    "repository": {
        "type": "git",
        "url": "https://github.com/jochenseeber/vscode-secret-resolver"
    },
    "version": "1.1.0-dev"
}
