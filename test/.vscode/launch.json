{
    "configurations": [
        {
            "name": "Test Shell Launch: Integrated Terminal",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "bash",
            "runtimeArgs": ["-c", "env | grep -E '^TEST_'"],
            "console": "integratedTerminal",
            "env": {
                "TEST_SECRET": "op://Employee/Secret Resolver Extension Test/password",
                "TEST_HELLO": "Hello, World!"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Test Shell Launch: External Terminal",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "bash",
            "runtimeArgs": ["-c", "env | grep -E '^TEST_'"],
            "console": "externalTerminal",
            "env": {
                "TEST_SECRET": "op://Employee/Secret Resolver Extension Test/password",
