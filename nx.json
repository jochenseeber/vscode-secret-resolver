{
    "$schema": "./node_modules/nx/schemas/nx-schema.json",
    "analytics": false,
    "namedInputs": {
        "default": [
            "sharedGlobals",
            "{projectRoot}/**/*"
        ],
        "production": [
            "!{projectRoot}/.github/**/*",
            "!{projectRoot}/CHANGELOG.md",
            "!{projectRoot}/README.md",
            "!{projectRoot}/docs/**/*",
            "!{projectRoot}/spec/**/*",
            "default"
        ],
        "scripts": [
            "{projectRoot}/scripts/**/*.ts"
        ],
        "sharedGlobals": [
            "{workspaceRoot}/dprint.json",
            "{workspaceRoot}/eslint.config.mjs",
            "{workspaceRoot}/tsconfig.json"
        ]
    },
    "targetDefaults": {}
}
